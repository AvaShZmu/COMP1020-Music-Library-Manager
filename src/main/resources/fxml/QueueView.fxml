<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox prefWidth="320" spacing="20" styleClass="queue-panel"
      xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="GUI.controller.QueueController">

    <padding>
        <Insets bottom="16" left="16" right="16" top="24" />
    </padding>

    <VBox spacing="12">
        <Label styleClass="queue-header-text" text="Now playing" />
        <ListView fx:id="nowPlayingListView" styleClass="queue-list" prefHeight="70">
            <VBox.margin>
                <Insets left="-10" right="-10" />
            </VBox.margin>
        </ListView>

    </VBox>

    <HBox alignment="BOTTOM_LEFT">
        <Label styleClass="queue-header-text" text="Next in queue" />
        <Region HBox.hgrow="ALWAYS" />
        <Button text="Clear queue" styleClass="queue-clear-btn" onAction="#handleClearQueue" />
    </HBox>

    <ListView fx:id="queueListView" styleClass="queue-list" VBox.vgrow="ALWAYS">
        <VBox.margin>
            <Insets left="-10" right="-10" />
        </VBox.margin>
    </ListView>

</VBox>