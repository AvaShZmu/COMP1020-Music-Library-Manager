<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.Slider?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<?import javafx.scene.control.ComboBox?>
<BorderPane minHeight="600" minWidth="900" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="GUI.controller.MainController">

    <!-- ═══════════════════════════════════════
         TOP BAR — search + app title
         ═══════════════════════════════════════ -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="16" styleClass="top-bar">

            <!-- App title -->
            <Label styleClass="app-title" text="♪  Music Library" />

            <!-- Spacer pushes search to center -->
            <Region HBox.hgrow="ALWAYS" />

            <!-- Search field -->
            <TextField fx:id="searchField" onKeyReleased="#handleSearch" prefWidth="500" maxWidth="700" HBox.hgrow="ALWAYS" promptText="Search songs, artists, albums…" styleClass="search-field" />

            <!-- Spacer pushes buttons to right -->
            <Region HBox.hgrow="ALWAYS" />

            <!-- Sort + Filter buttons -->
            <ComboBox fx:id="sortComboBox"
                      styleClass="filter-combo"
                      prefWidth="130"
                      onAction="#handleSort"/>

            <Button fx:id="btnFilter"
                    text="Filter"
                    styleClass="btn-secondary"
                    onAction="#handleFilter"
                    prefWidth="80"/>

            <Button fx:id="btnClearFilter"
                    text="✕ filter"
                    styleClass="btn-danger"
                    onAction="#handleClearFilter"
                    visible="false"
                    managed="false"/>

        </HBox>
    </top>

    <!-- ═══════════════════════════════════════
         LEFT — sidebar navigation
         ═══════════════════════════════════════ -->
    <left>
        <VBox prefWidth="210" spacing="0" styleClass="sidebar">

            <!-- LIBRARY section -->
            <Label styleClass="nav-section-header" text="LIBRARY" />

            <Button fx:id="btnAllTracks" maxWidth="Infinity" onAction="#showLibrary" styleClass="nav-item" text="♪   All Tracks" />

            <Button fx:id="btnFavourites" maxWidth="Infinity" onAction="#showFavourites" styleClass="nav-item" text="♥   Favourites" />

            <!-- PLAYLISTS section -->
            <Label styleClass="nav-section-header" text="PLAYLISTS" />
         <TextField fx:id="playlistSearchField" onKeyReleased="#handlePlaylistSearch" promptText="Search playlists..." styleClass="sidebar-search" />

            <!-- Playlist list — populated dynamically from PlaylistStorage -->
            <ListView fx:id="playlistNavList" maxHeight="Infinity" prefWidth="190.0" styleClass="playlist-nav-list" VBox.vgrow="ALWAYS" />

            <!-- New Playlist button pinned to bottom -->
            <VBox alignment="BOTTOM_CENTER">
                <padding><Insets bottom="16" left="12" right="12" top="8" /></padding>
                <Button maxWidth="Infinity" onAction="#handleNewPlaylist" styleClass="btn-primary" text="+ New Playlist" />
            </VBox>

        </VBox>
    </left>

    <!-- ═══════════════════════════════════════
         CENTER — swappable content area
         ═══════════════════════════════════════ -->
    <center>
        <!-- StackPane lets us swap child views by
             calling getChildren().setAll(loader.load()) -->
        <StackPane fx:id="contentArea" styleClass="content-area" />
    </center>

    <!-- ═══════════════════════════════════════
         BOTTOM — playback bar (always visible)
         ═══════════════════════════════════════ -->
    <bottom>
        <StackPane fx:id="bottomContainer" />
    </bottom>

</BorderPane>
