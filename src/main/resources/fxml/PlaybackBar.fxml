<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>

<HBox fx:id="playbackBar" alignment="CENTER" prefHeight="88" spacing="0" styleClass="playback-bar" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="GUI.controller.playback.PlaybackBarController">

    <HBox alignment="CENTER_LEFT" prefWidth="250" spacing="12">
        <StackPane maxHeight="60" maxWidth="60" prefHeight="60" prefWidth="60" styleClass="now-playing-art-container">
            <Label fx:id="fallbackIcon" styleClass="now-playing-fallback-icon" text="♪" />
            <ImageView fx:id="nowPlayingImage" fitHeight="60" fitWidth="60" preserveRatio="true" styleClass="now-playing-image" />
        </StackPane>
        <VBox alignment="CENTER_LEFT" prefWidth="220" spacing="3">
            <HBox.margin><Insets left="4" /></HBox.margin>
            <Label fx:id="nowPlayingTitle" styleClass="now-playing-title" text="No Track Selected" />
            <Label fx:id="nowPlayingArtist" styleClass="now-playing-artist" text="Unknown Artist" />
        </VBox>
    </HBox>

    <VBox alignment="CENTER" spacing="8" HBox.hgrow="ALWAYS">
        <HBox alignment="CENTER" spacing="6" styleClass="playback-controls">

            <Button fx:id="btnPrevious" onAction="#handlePrevious" styleClass="btn-playback">
                <graphic>
                    <SVGPath styleClass="playback-icon" content="M6 6h2v12H6zm3.5 6l8.5 6V6z" />
                </graphic>
            </Button>

            <Button fx:id="btnPlayPause" onAction="#handlePlayPause" styleClass="btn-play-pause">
                <graphic>
                    <SVGPath fx:id="playPauseIcon" content="M8 5v14l11-7z" fill="#000000" />
                </graphic>
            </Button>

            <Button fx:id="btnNext" onAction="#handleNext" styleClass="btn-playback">
                <graphic>
                    <SVGPath styleClass="playback-icon" content="M6 18l8.5-6L6 6v12zM16 6v12h2V6h-2z" />
                </graphic>
            </Button>

        </HBox>

        <HBox alignment="CENTER" spacing="8">
            <Label fx:id="currentTimeLabel" styleClass="time-label" text="0:00" />
            <Slider fx:id="progressSlider" max="100" min="0" onMousePressed="#handleProgressPressed" onMouseReleased="#handleProgressReleased" prefWidth="300" styleClass="progress-slider" value="0" />
            <Label fx:id="totalTimeLabel" styleClass="time-label" text="0:00" />
        </HBox>
    </VBox>

    <HBox alignment="CENTER_RIGHT" prefWidth="180" spacing="8">
        <HBox.margin><Insets right="4" /></HBox.margin>

        <Button fx:id="btnQueue" onAction="#handleQueueToggle" styleClass="btn-queue">
            <graphic>
                <SVGPath content="M3 18h18v-2H3v2zm0-5h18v-2H3v2zm0-7v2h18V6H3z" styleClass="queue-icon" />
            </graphic>
        </Button>

        <Label styleClass="volume-icon">
            <graphic>
                <SVGPath content="M3 9v6h4l5 5V4L7 9H3zm13.5 3c0-1.77-1.02-3.29-2.5-4.03v8.05c1.48-.73 2.5-2.25 2.5-4.02zM14 3.23v2.06c2.89.86 5 3.54 5 6.71s-2.11 5.85-5 6.71v2.06c4.01-.91 7-4.49 7-8.77s-2.99-7.86-7-8.77z" fill="#E0E0E0" />
            </graphic>
        </Label>

        <Slider fx:id="volumeSlider" max="1" min="0" prefWidth="90" styleClass="volume-slider" value="0.7" />
    </HBox>

</HBox>
