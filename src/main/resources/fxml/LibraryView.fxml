<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.yourname.controller.LibraryController"
      styleClass="content-area"
      VBox.vgrow="ALWAYS">

    <!-- Header -->
    <VBox styleClass="content-header">
        <Label fx:id="contentTitle"
               text="All Tracks"
               styleClass="content-title"/>
        <Label fx:id="trackCountLabel"
               text="0 songs"
               styleClass="content-subtitle"/>
    </VBox>

    <!-- Toolbar -->
    <HBox styleClass="toolbar" spacing="10" alignment="CENTER_LEFT">
        <Button fx:id="btnImport"
                text="+ Import Audio"
                styleClass="btn-primary"
                onAction="#handleImport"/>
        <Button fx:id="btnRemove"
                text="Remove"
                styleClass="btn-secondary"
                onAction="#handleRemove"/>
    </HBox>

    <!-- Card grid -->
    <ScrollPane VBox.vgrow="ALWAYS"
                fitToWidth="true"
                styleClass="card-scroll-pane">
        <FlowPane fx:id="cardGrid"
                  styleClass="card-grid"
                  hgap="16" vgap="16"/>
    </ScrollPane>

</VBox>