<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="GUI.controller.LibraryController"
      styleClass="content-area"
      VBox.vgrow="ALWAYS">

    <!-- Header -->
    <VBox styleClass="content-header">
        <Label fx:id="contentTitle"
               text="All Tracks"
               styleClass="content-title"/>
        <Label fx:id="trackCountLabel"
               text="0 songs"
               styleClass="content-subtitle"/>
    </VBox>

    <!-- Toolbar -->
    <HBox styleClass="toolbar" spacing="10" alignment="CENTER_LEFT">
        <Button fx:id="btnImport"
                text="+ Import Audio"
                styleClass="btn-primary"
                onAction="#handleImport"/>


        <ComboBox fx:id="sortComboBox"
                  styleClass="filter-combo"
                  prefWidth="130"
                  onAction="#handleSort"/>

        <Button fx:id="btnFilter"
                text="Filter"
                styleClass="btn-secondary"
                onAction="#handleFilter"
                prefWidth="80"/>

        <Button fx:id="btnClearFilter"
                text="✕ filter"
                styleClass="btn-danger"
                onAction="#handleClearFilter"
                visible="false"
                managed="false"/>
    </HBox>

    <!-- Card grid -->
    <ScrollPane VBox.vgrow="ALWAYS"
                fitToWidth="true"
                styleClass="card-scroll-pane">
        <FlowPane fx:id="cardGrid"
                  styleClass="card-grid"
                  hgap="16" vgap="16"/>
    </ScrollPane>

</VBox>